# ==============================================================================
# Crystal Group — AI-Powered Hiring System
# Copy this file to .env.local for local development.
# On Vercel, paste each key into Project Settings → Environment Variables.
# ==============================================================================

# ------------------------------------------------------------------------------
# Google Sheets (primary database)
# ------------------------------------------------------------------------------
# Your Google Sheet ID — the long string between /d/ and /edit in the URL
GOOGLE_SHEETS_SPREADSHEET_ID=your_sheet_id_here

# Service account email from Google Cloud Console
# (IAM & Admin → Service Accounts → your account → Email)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Service account private key from the JSON key file.
# IMPORTANT: Keep the -----BEGIN/END PRIVATE KEY----- markers and
# replace real newlines with \n (escaped). On Vercel, paste the
# whole thing including quotes. The app converts \n back to newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQI...\n-----END PRIVATE KEY-----\n"

# ------------------------------------------------------------------------------
# Google Drive (file storage: resumes, recordings, documents, offer letters)
# ------------------------------------------------------------------------------
# Shared Drive ID where HIRING/ folder will be created.
# For a shared drive: the ID is in the URL after /drive/folders/
# For a regular folder: the folder ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_or_shared_drive_id

# ------------------------------------------------------------------------------
# AI (OpenRouter → Gemini 2.0 Flash)
# ------------------------------------------------------------------------------
# Sign up at https://openrouter.ai → Keys → Create new key
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ------------------------------------------------------------------------------
# Auth (JWT session signing)
# ------------------------------------------------------------------------------
# Generate a strong random string — any 32+ char secret works.
# On Linux/macOS: openssl rand -base64 32
# On Windows:     [Convert]::ToBase64String((1..32 | % {Get-Random -Max 256}))
JWT_SECRET=change_me_to_a_strong_random_string

# ------------------------------------------------------------------------------
# Email (SMTP via Gmail with App Password)
# ------------------------------------------------------------------------------
# Enable 2-Step Verification on the Google account, then create an App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-hr-email@yourcompany.com
SMTP_PASS=your16charapppassword
# The From: header address (can differ from SMTP_USER for Brevo/SendGrid etc.)
SMTP_FROM=your-hr-email@yourcompany.com

# ------------------------------------------------------------------------------
# App URL
# ------------------------------------------------------------------------------
# Used as the base URL for email links (token links for candidates etc.)
# Local:     http://localhost:3000
# Vercel:    https://your-project.vercel.app  (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Cloudinary (optional — currently unused, kept for future fallback uploads)
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
